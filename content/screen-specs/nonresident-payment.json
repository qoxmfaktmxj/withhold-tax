      "label": "대상자 유형",
      "type": "enum",
      "required": true,
      "source": "manual",
      "validation": "비거주자(개인)|외국법인"
    },
    {
      "key": "residenceCountry",
      "label": "거주지국 (조약 체결국)",
      "type": "string(ISO-3166)",
      "required": true,
      "source": "manual"
    },
    {
      "key": "incomeType",
      "label": "소득 유형",
      "type": "enum",
      "required": true,
      "source": "manual",
      "validation": "이자|배당|사업|사용료|근로|기타"
    },
