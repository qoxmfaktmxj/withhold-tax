    {
      "key": "taxOfficeFilingDate",
      "label": "세무서 제출일",
      "type": "date|null",
      "required": false,
      "source": "manual"
    },
    {
      "key": "filingDeadline",
      "label": "제출 기한",
      "type": "date",
      "required": true,
      "source": "rule",
      "helpText": "지급연도 익년 2월 말일"
    },
    {
      "key": "attachments",
      "label": "첨부 서류 목록",
