[
  {
    "ruleId": "wht_late_payment_penalty",
    "version": "2026.1.0",
    "calendarYear": 2026,
    "name": "원천징수 등 납부지연가산세(현행 — 2026.6.30까지 지정납부기한 도래분)",
    "domain": "penalty",
    "incomeType": "all",
    "effectiveFrom": "2019-01-01",
    "effectiveTo": "2026-06-30",
    "factIds": ["f_a00004", "f_c40003"],
    "inputs": [
      { "key": "unpaidTax", "type": "number", "required": true, "description": "미납·과소납부 세액(원)" },
      { "key": "daysLate", "type": "number", "required": true, "description": "법정납부기한 다음 날부터 납부일(고지일)까지 일수" }
    ],
    "formula": {
      "type": "penalty-late-wht",
      "expression": "MIN(미납세액×3% + 미납세액×일수×22/100,000, 미납세액×10%) — 전체 한도 50%",
      "params": { "baseRate": 0.03, "dailyRate": 0.00022, "innerCap": 0.1, "outerCap": 0.5 }
    },
    "examples": [
      {
        "title": "미납 1,000,000원·100일 지연",
        "input": { "unpaidTax": 1000000, "daysLate": 100 },
        "expected": { "total": 52000, "capApplied": false }
      },
      {
        "title": "미납 1,000,000원·400일 지연(한도 도달)",
        "input": { "unpaidTax": 1000000, "daysLate": 400 },
        "expected": { "total": 100000, "capApplied": true }
      }
    ],
    "warnings": [
      "약 319일에 10% 한도 도달",
      "원천세는 신고불성실 가산세 없이 납부지연 가산세만 적용",
      "지방소득세 특별징수 가산세는 지방세기본법 별도 체계"
    ]
  },
  {
    "ruleId": "wht_late_payment_penalty",
    "version": "2026.7.0",
    "calendarYear": 2026,
    "name": "원천징수 등 납부지연가산세(2026.7.1 이후 지정납부기한 도래분 — 개정)",
    "domain": "penalty",
    "incomeType": "all",
    "effectiveFrom": "2026-07-01",
    "factIds": ["f_c40017"],
    "inputs": [
      { "key": "unpaidTax", "type": "number", "required": true, "description": "미납·과소납부 세액(원)" },
      { "key": "daysLate", "type": "number", "required": true, "description": "법정납부기한 다음 날부터 납부일까지 일수(고지 전 구간)" },
      { "key": "noticeDate", "type": "date", "required": false, "description": "납부고지일" },
      { "key": "designatedDueDate", "type": "date", "required": false, "description": "납부고지서상 지정납부기한" },
      { "key": "demandCost", "type": "number", "required": false, "description": "독촉비용(고지서·우편 고시 기준 입력)" }
    ],
    "formula": {
      "type": "penalty-late-wht",
      "expression": "기본 3% + 일할이자(고지 전) + [개정] 지정납부기한 후 월할 이자 + 독촉비용 — 10%/50% 한도 유지, 체납 150만원 미만 월할·독촉비용 면제, 기간 5년 상한",
      "params": {
        "baseRate": 0.03,
        "dailyRate": 0.00022,
        "monthlyRate": 0.0067,
        "innerCap": 0.1,
        "outerCap": 0.5,
        "smallTaxExemption": 1500000,
        "maxPostDesignatedMonths": 60
      }
    },
    "calculationMode": "manual-review",
    "examples": [
      {
        "title": "미납 2,000,000원·고지 전 30일·지정납부기한 후 3개월·독촉비용 2,500원",
        "input": { "unpaidTax": 2000000, "daysLate": 30, "designatedDueDate": "2026-08-20", "paymentDate": "2026-11-20", "demandCost": 2500 },
        "expected": { "basePenalty": 60000, "preNoticeDailyPenalty": 13200, "postDesignatedMonthlyPenalty": 40200, "demandCost": 2500, "total": 115900, "manualReviewRequired": true }
      }
    ],
    "warnings": [
      "지정납부기한 후 월할 이자율은 월 1만분의 67",
      "독촉비용은 고지서·우편 고시 기준 금액을 입력하고 수동 검토",
      "2026.7.1 전후 분기 적용(경과조치 있음) — 세무담당자 확인 필수"
    ]
  },
  {
    "ruleId": "payment_statement_penalty",
    "version": "2026.1.0",
    "calendarYear": 2026,
    "name": "지급명세서 미제출·지연제출 가산세",
    "domain": "penalty",
    "incomeType": "all",
    "effectiveFrom": "2019-01-01",
    "factIds": ["f_c40004", "f_c40005", "f_c40006", "f_c40008"],
    "inputs": [
      { "key": "amount", "type": "number", "required": true, "description": "미제출·지연제출 지급금액(원)" },
      { "key": "statementType", "type": "enum", "required": true, "description": "지급명세서(연) 또는 간이지급명세서" },
      { "key": "submissionStatus", "type": "enum", "required": true, "description": "미제출 또는 지연제출" },
      { "key": "companySize", "type": "enum", "required": true, "description": "일반기업 또는 중소기업" }
    ],
    "formula": {
      "type": "custom",
      "expression": "지급명세서 미제출 = 지급금액 × 1%, 지연제출 = 지급금액 × 0.5%; 간이지급명세서 미제출 = 지급금액 × 0.25%, 지연제출 = 지급금액 × 0.125% — 한도: 일반기업 1억원·중소기업 5천만원",
      "params": {
        "missRate": 0.01,
        "lateRate": 0.005,
        "simpleMissRate": 0.0025,
        "simpleLateRate": 0.00125,
        "generalCap": 100000000,
        "smeCap": 50000000
      }
    },
    "calculationMode": "manual-review",
    "examples": [
      {
        "title": "지급명세서 미제출 10,000,000원",
        "input": { "amount": 10000000, "statementType": "annual", "submissionStatus": "missing", "companySize": "general" },
        "expected": { "total": 100000, "capApplied": false }
      },
      {
        "title": "간이지급명세서 지연제출 10,000,000원",
        "input": { "amount": 10000000, "statementType": "simplified", "submissionStatus": "late", "companySize": "general" },
        "expected": { "total": 12500, "capApplied": false }
      }
    ],
    "warnings": ["간이지급명세서 지연제출 경감기간은 소득 유형과 귀속연도별 특례를 별도 확인"]
  }
]
