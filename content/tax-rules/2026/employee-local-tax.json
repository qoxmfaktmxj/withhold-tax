[
  {
    "ruleId": "employee_local_tax",
    "version": "2026.1.0",
    "calendarYear": 2026,
    "name": "종업원분 주민세(2026 — 장기근속수당·육아휴직 대체인력 공제 신설 반영)",
    "domain": "employee-local-tax",
    "incomeType": "earned",
    "effectiveFrom": "2026-01-01",
    "factIds": [
      "f_lt0021",
      "f_lt0022",
      "f_lt0023",
      "f_lt0024",
      "f_lt0025",
      "f_lt0026",
      "f_lt0027",
      "f_lt0028",
      "f_lt0029",
      "f_lt0030",
      "f_u26006",
      "f_u26007"
    ],
    "inputs": [
      {
        "key": "avgMonthlyPayroll",
        "type": "number",
        "required": true,
        "description": "신고 대상 월 포함 직전 12개월 월평균 급여총액(원) — 면세점 판정용"
      },
      {
        "key": "monthlyPayrollTotal",
        "type": "number",
        "required": true,
        "description": "당월 종업원 급여총액(원) — 비과세 급여(소득세법 §12 제3호) 제외"
      },
      {
        "key": "longServiceEmployeeCount",
        "type": "number",
        "required": false,
        "description": "장기근속수당 지급 인원 수(명)"
      },
      {
        "key": "longServiceAllowancePerEmployee",
        "type": "number",
        "required": false,
        "description": "1인당 장기근속수당 지급액(원/월)"
      },
      {
        "key": "longServiceMonthlyPayPerEmployee",
        "type": "number",
        "required": false,
        "description": "장기근속수당 지급 직원의 1인당 월급여(원) — 공제한도(10%) 산정용"
      },
      {
        "key": "childcareReplacementPay",
        "type": "number",
        "required": false,
        "description": "육아휴직 대체인력 급여 합계(원) — 전액 공제"
      },
      {
        "key": "otherDeduction",
        "type": "number",
        "required": false,
        "description": "기타 과세표준 공제(원) — 중소기업 고용지원 공제(§84의5) 등 별도 계산값 직접 입력"
      },
      {
        "key": "paymentMonth",
        "type": "string",
        "required": false,
        "description": "급여 지급월 YYYY-MM — 신고기한(다음 달 10일) 계산용"
      }
    ],
    "formula": {
      "type": "custom",
      "expression": "면세점: 직전 12개월 월평균 급여총액 ≤ 1억5천만원 → 면세(신고의무 없음). 과세분: 세액 = (당월 급여총액 − Σ MIN(1인당 장기근속수당, 1인당 월급여×10%, 360,000원) − 육아휴직 대체인력 급여 전액 − 기타 공제) × 0.5% — 신고기한은 급여 지급한 달의 다음 달 10일. 전용 계산 함수 lib/employee-local-tax/check.ts 사용",
      "params": {
        "standardRate": 0.005,
        "minRateByOrdinance": 0.0025,
        "maxRateByOrdinance": 0.0075,
        "exemptionThreshold": 150000000,
        "longServiceRate": 0.1,
        "longServiceCapPerPerson": 360000,
        "filingDeadlineDay": 10
      }
    },
    "rounding": {
      "base": 10,
      "method": "floor"
    },
    "calculationMode": "manual-review",
    "examples": [
      {
        "title": "강의 종합사례(Slide 54) — ㈜한백테크 2026년 5월분",
        "input": {
          "avgMonthlyPayroll": 180000000,
          "monthlyPayrollTotal": 180000000,
          "longServiceEmployeeCount": 10,
          "longServiceAllowancePerEmployee": 400000,
          "longServiceMonthlyPayPerEmployee": 4000000,
          "childcareReplacementPay": 15000000,
          "otherDeduction": 14940000,
          "paymentMonth": "2026-05"
        },
        "expected": {
          "exempt": false,
          "longServiceDeduction": 3600000,
          "childcareDeduction": 15000000,
          "otherDeduction": 14940000,
          "taxBase": 146460000,
          "tax": 732300,
          "filingDeadline": "2026-06-10"
        }
      },
      {
        "title": "면세점 이하 — 월평균 급여총액 1억 4천만원",
        "input": {
          "avgMonthlyPayroll": 140000000,
          "monthlyPayrollTotal": 140000000
        },
        "expected": {
          "exempt": true,
          "tax": 0
        }
      },
      {
        "title": "공제 없음 — 당월 급여총액 2억원",
        "input": {
          "avgMonthlyPayroll": 200000000,
          "monthlyPayrollTotal": 200000000
        },
        "expected": {
          "exempt": false,
          "taxBase": 200000000,
          "tax": 1000000
        }
      }
    ],
    "warnings": [
      "표준세율 0.5%는 지자체 조례로 100분의 50 범위에서 가감 가능(0.25%~0.75%) — 사업소 소재지 조례 확인 필요",
      "중소기업 고용지원 공제(지방세법 §84의5)는 직전연도 월평균 종업원 수 기준으로 별도 계산해 기타 공제액으로 입력",
      "2026 신설 장기근속수당·육아휴직 대체인력 공제는 강의(2025.12.30. 본회의 통과 기준) 기반 — 시행 법령 원문 확인 필요",
      "사업소 소재지 시·군·구별로 각각 신고·납부 — 신고기한은 급여를 지급한 달의 다음 달 10일",
      "면세점 적용 시 별도 신고의무 없음(다만 매월 면세점 판단은 필수), 영업일 15일 미만인 달은 월평균 산정에서 제외"
    ]
  }
]
