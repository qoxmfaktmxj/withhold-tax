  {
    "ruleId": "daily_worker_filings",
    "version": "2026.1.0",
    "calendarYear": 2026,
    "name": "일용근로 신고 3종 기한(원천세·근로내용확인신고서·지급명세서)",
    "domain": "deadline",
    "incomeType": "daily_worker",
    "effectiveFrom": "2021-07-01",
    "factIds": [
      "f_dw0009",
      "f_dw0010",
      "f_dw0011",
      "f_dw0012",
      "f_dw0017",
      "f_dw0025"
    ],
    "inputs": [
      {
        "key": "paymentDate",
        "type": "date",
        "required": true,
        "description": "일용근로소득 지급일"
      }
    ],
    "formula": {
      "type": "date-rule",
      "expression": "원천세 신고·납부 = 지급월 다음달 10일(A03란, 세액 없어도 기재) / 근로내용확인신고서 = 다음달 15일(고용센터, 제출 시 지급명세서 의제) / 일용근로소득지급명세서 = 다음달 말일(홈택스)",
      "params": {
        "basis": "payment_month",
        "offsetMonths": 1,
        "day": 10
      }
    },
    "calculationMode": "automatic",
    "examples": [
      {
        "title": "2026년 1월 지급 일용근로소득 — 원천세 기준 기한",
        "input": {
          "paymentDate": "2026-01-20"
        },
        "expected": {
          "dueDate": "2026-02-10"
        }
      }
    ],
    "warnings": [
      "근로내용확인신고서는 다음달 15일까지 고용센터 제출 — 기한 내 제출 시 일용근로소득지급명세서 제출 의제(소득령 제213조)",
      "일용근로소득지급명세서는 다음달 말일까지 홈택스 제출",
      "12.31까지 미지급한 12월분은 익년 1월 말까지 지급명세서 제출"
    ]
  }
