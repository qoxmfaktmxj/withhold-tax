    "formula": {
      "type": "composite-rates",
      "expression": "공제 = 국민연금 4.75%(기준소득월액 41만~659만, 2026.7.1~) + 건강보험 3.595% + 장기요양(건보료×13.14%) + 고용보험 0.9% + 연 환산 근사 소득세[근로소득공제(§47)→인적공제(150만×인원)→연금보험료공제→기본세율(§55)→근로소득세액공제(§59)]÷12 + 지방소득세(소득세×10%); 세후→세전 역산은 고정점 반복(감쇠 0.85·오차 1원·최대 100회). 실제 계산은 lib/reverse-net-pay/calc.ts",
      "params": {
        "nationalPensionEmployeeRate": 0.0475,
        "nationalPensionMonthlyBaseCap": 6590000,
        "nationalPensionMonthlyBaseFloor": 410000,
        "healthInsuranceEmployeeRate": 0.03595,
        "longTermCareRateOnHealthInsurance": 0.1314,
        "employmentInsuranceEmployeeRate": 0.009,
        "localIncomeTaxRate": 0.1,
        "personalDeductionPerPerson": 1500000
      }
    },
    "rounding": {
      "base": 10,
      "method": "floor"
    },
    "calculationMode": "manual-review",
    "examples": [
      {
        "title": "희망 실수령 4,000,000원·부양 1인·비과세 0원 → 세전 4,866,981원",
