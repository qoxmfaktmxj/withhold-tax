    "calendarYear": 2026,
    "name": "지방소득세 특별징수(원천징수세액의 10%)",
    "domain": "local-income-tax",
    "incomeType": "all",
    "effectiveFrom": "2018-01-01",
    "factIds": ["f_nr0015", "f_c40015"],
    "inputs": [
      { "key": "nationalTax", "type": "number", "required": true, "description": "원천징수 소득세·법인세액(원)" }
    ],
    "formula": {
      "type": "rate",
      "expression": "지방소득세 특별징수 = 원천징수세액 × 10%, 징수일 다음 달 10일까지 관할 지자체 납부",
      "params": { "rate": 0.1 }
    },
    "rounding": { "base": 10, "method": "floor" },
    "examples": [
      {
        "title": "원천세 30,000원",
        "input": { "grossPayment": 30000 },
        "expected": { "nationalTax": 3000 }
      }
    ],
    "warnings": [
      "국세와 지방세를 한 rule·한 신고서에 섞지 말 것 — 납부처(세무서 vs 지자체)와 가산세 체계가 다름",
      "근로·퇴직소득 특별징수분 납세지는 근무지, 그 외는 지급지 기준(지방세법 §89②)",
      "조세조약 적용 비거주자 소득은 지방세 안분 별도 확인"
    ]
  }
]
